%% -*- mode: erlang;erlang-indent-level: 4;indent-tabs-mode: nil -*-

{erl_opts, [debug_info, warnings_as_errors]}.
{src_dirs, [{"src", [{recursive, true}]}]}.
{shell, [{config, "./config/dev_sys.config.src"}]}.

{deps, [
    %% Nova fork carrying nova_jsonlogger (novaframework/nova#385); pinned to a
    %% SHA while Nova is pre-release, matching the other Nova apps in the org.
    {nova,
        {git, "https://github.com/Taure/nova.git",
            {ref, "aad5296d579e34ed71ac6203c03f60eb19e8ca1e"}}},
    {kura, {git, "https://github.com/Taure/kura.git", {tag, "v2.0.6"}}},
    {kura_postgres, {git, "https://github.com/Taure/kura_postgres.git", {tag, "v0.4.2"}}}
]}.

{provider_hooks, [
    {pre, [{compile, {kura, compile}}]}
]}.

{relx, [
    {release, {sekisho, git}, [
        sekisho,
        sasl
    ]},
    {mode, dev},
    {sys_config_src, "./config/dev_sys.config.src"},
    {vm_args_src, "./config/vm.args.src"}
]}.

{profiles, [
    {prod, [
        {relx, [
            {mode, prod},
            {sys_config_src, "./config/prod_sys.config.src"}
        ]}
    ]},
    {test, [
        {erl_opts, [debug_info, nowarn_export_all]},
        {ct_opts, [{sys_config, "./config/dev_sys.config.src"}]},
        {extra_src_dirs, [{"test", [{recursive, true}]}]},
        {xref_extra_paths, ["test"]}
    ]}
]}.

{project_plugins, [
    {rebar3_nova, {git, "https://github.com/novaframework/rebar3_nova.git", {branch, "master"}}},
    {rebar3_kura, "0.13.1"},
    erlfmt,
    rebar3_ex_doc,
    rebar3_lint,
    rebar3_hank,
    {rebar3_audit, {git, "https://github.com/Taure/rebar3_audit.git", {branch, "main"}}},
    {rebar3_sbom,
        {git, "https://github.com/Taure/rebar3_sbom.git", {branch, "feat/include-otp-components"}}},
    covertool
]}.

{hex, [{doc, ex_doc}]}.

{erlfmt, [write, {exclude_files, ["config/vm.args.src", "config/prod_sys.config.src"]}]}.

{hank, [
    {ignore, [
        "test/**"
    ]}
]}.

{dialyzer, [
    {warnings, [error_handling, unmatched_returns, unknown]},
    {plt_apps, all_deps}
]}.

{xref_checks, [undefined_function_calls, undefined_functions, locals_not_used]}.

{cover_enabled, true}.

{ex_doc, [
    {extras, [
        <<"README.md">>,
        <<"docs/adr/0001-gateway-security-model.md">>
    ]},
    {main, <<"readme">>},
    {proglang, erlang},
    {source_url, <<"https://github.com/Taure/sekisho">>}
]}.
